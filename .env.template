# Set the local port for this gateway. Default: 8421.
OAUTH2_GATEWAY_PORT=8421

# Set the preregistered OAuth client ID this gateway will accept.
# Copy this into your AI app's connector/app OAuth configuration screen.
OAUTH2_GATEWAY_CLIENT_ID=oauth2-gateway-client

# Set the preregistered OAuth client secret this gateway will require.
# Copy this into your AI app's connector/app OAuth configuration screen.
# Generate with: openssl rand -hex 32
OAUTH2_GATEWAY_CLIENT_SECRET=

# Set the username you will enter when your AI app prompts you to sign in.
USERNAME=

# Set the password you will enter when your AI app prompts you to sign in.
PASSWORD=

# Require PKCE for the OAuth authorization-code flow. Recommended.
# Set this to false only if your client cannot send PKCE.
OAUTH2_PKCE_REQUIRED=true

# Set the bearer token this gateway will return after a successful token exchange.
# Generate with: openssl rand -hex 32
OAUTH2_GATEWAY_ACCESS_TOKEN=

# URL of the upstream MCP server. Default: http://127.0.0.1:8420
OAUTH2_GATEWAY_MCP_UPSTREAM_URL=http://127.0.0.1:8420

# Path to the shared secret file used to authenticate to the MCP server.
# Default: /tmp/brain3-mcp-upstream-secret/upstream_secret
OAUTH2_GATEWAY_UPSTREAM_SECRET_FILE=/tmp/brain3-mcp-upstream-secret/upstream_secret

# --- Cloudflare Tunnel (pick one option or use DIRECT_PUBLIC_ORIGIN_HOSTNAME below) ---

# Option A: Quick tunnel — no DNS or config needed, URL changes on each restart.
# Set to true and the gateway will start cloudflared automatically on startup.
CF_QUICK_TUNNEL=false

# Option B: Named tunnel on your own domain (stable hostname).
# Requires cloudflared to be installed and the tunnel to be pre-provisioned
# (run the setup wizard first). When these are set the gateway starts
# cloudflared automatically on startup.
# The public hostname will be: <CF_TUNNEL_NAME>.<CF_DOMAIN>
# Example: CF_TUNNEL_NAME=brain3, CF_DOMAIN=yourserver.com -> brain3.yourserver.com
CF_TUNNEL_NAME=
CF_DOMAIN=
# Required when CF_TUNNEL_NAME and CF_DOMAIN are set.
# Path to the cloudflared config file written by the setup wizard.
# Example: /Users/yourname/.cloudflared/brain3.yml
CF_TUNNEL_CONFIG_FILE=

# Set this only if the machine is already publicly reachable and you are using
# a direct public origin behind Cloudflare proxy, typically with Caddy or nginx
# terminating TLS in front of this gateway.
# Example:
#   DIRECT_PUBLIC_ORIGIN_HOSTNAME=brain3.yourserver.com
# Leave this empty if you are using either Cloudflare Tunnel flow.
DIRECT_PUBLIC_ORIGIN_HOSTNAME=

# Control whether the gateway enforces hostname checking.
# Default: true
# Only set to false if you intentionally want to skip hostname matching.
OAUTH2_GATEWAY_ENFORCE_HOSTNAME_CHECK=true

# Container runtime management (required).
# Set to 'macos-container' (macOS native containers) or 'docker'.
BRAIN3_CONTAINER_RUNTIME=

# Absolute path to your Obsidian vault on the host.
BRAIN3_VAULT_PATH=

# Container image, name, and host port (defaults shown).
BRAIN3_CONTAINER_IMAGE=obsidian-mcp-server:latest
BRAIN3_CONTAINER_NAME=obsidian-mcp-server
BRAIN3_CONTAINER_HOST_PORT=8420
