# Required: path to your Obsidian vault directory
B3_VAULT_PATH=/path/to/your/obsidian_vaults

# Optional: port to listen on (default: 2765)
B3_VAULT_MCP_PORT=2765

# Optional: comma-separated extra allowed Host headers for DNS rebinding protection
# Example: B3_VAULT_MCP_ALLOWED_HOSTS=vault-mcp.example.com,mcp2.dev
B3_VAULT_MCP_ALLOWED_HOSTS=

# Optional: log level (default: INFO). Set to TRACE to log full request/response
# bodies sent to and from the MCP server, e.g. when debugging client errors.
B3_VAULT_MCP_LOG_LEVEL=INFO
